#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspaces/Camber-and-Casper-Mock/node_modules/.pnpm/orval@8.8.1_prettier@3.8.3_typescript@5.9.3/node_modules/orval/node_modules:/workspaces/Camber-and-Casper-Mock/node_modules/.pnpm/orval@8.8.1_prettier@3.8.3_typescript@5.9.3/node_modules:/workspaces/Camber-and-Casper-Mock/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspaces/Camber-and-Casper-Mock/node_modules/.pnpm/orval@8.8.1_prettier@3.8.3_typescript@5.9.3/node_modules/orval/node_modules:/workspaces/Camber-and-Casper-Mock/node_modules/.pnpm/orval@8.8.1_prettier@3.8.3_typescript@5.9.3/node_modules:/workspaces/Camber-and-Casper-Mock/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../dist/bin/orval.mjs" "$@"
else
  exec node  "$basedir/../../dist/bin/orval.mjs" "$@"
fi
