{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"App.tsx\" \"pages/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\" \"store/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"App.tsx\" \"pages/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\" \"store/**/*.ts\" --fix",
    "format": "prettier --write \"App.tsx\" \"pages/**\" \"components/**\" \"lib/**\" \"store/**\"",
    "format:check": "prettier --check \"App.tsx\" \"pages/**/*.tsx\" \"components/**/*.tsx\" \"lib/**/*.ts\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "private": true,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "~5.9.2",
    "vite": "catalog:",
    "vitest": "^4.1.4",
    "zustand": "^5.0.12"
  },
