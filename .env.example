# ──────────────────────────────────────────────────────────
# Camber & Casper Systems — API Server Environment Variables
# ──────────────────────────────────────────────────────────
#
# Copy this file to .env and fill in your keys.
#
# On Replit: Use the Secrets tab (lock icon in left sidebar)
#            to set each variable instead of a .env file.
#            Replit automatically injects Secrets as env vars.
#
# On local dev: Copy to .env in the project root:
#   cp .env.example .env
#
# ──────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────
PORT=3001

# ── Vapi.ai (Voice AI Platform) ──────────────────────────
# Get these from https://dashboard.vapi.ai/
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# Public webhook URL — Vapi sends call events here.
# On Replit: https://your-repl-name.your-username.repl.co/api/vapi/webhook
# On local: Use ngrok or similar to expose localhost:3001
VAPI_WEBHOOK_URL=

# ── Twilio (Phone Infrastructure) ────────────────────────
# Australian number for caller ID (e.g. +613XXXXXXXX for VIC)
TWILIO_PHONE_NUMBER=

# ── Voice Configuration ──────────────────────────────────
# Default: Isabella (Vapi-native ElevenLabs voice, no key needed)
VOICE_PROVIDER=11labs
ELEVENLABS_VOICE_ID=ZkDZ5VCyH0GGbxO7o4aO

# ── LLM Configuration ────────────────────────────────────
# Default: Groq + Llama 3.3 70B (ultra-low latency)
VAPI_LLM_PROVIDER=groq
VAPI_LLM_MODEL=llama-3.3-70b-versatile
